{"noir_version":"1.0.0-beta.22+c57152f91260ecdb9faad4efc20abb14b6d2ece7","name":"SimpleLogging","functions":[{"name":"__aztec_nr_internals__get_counter","hash":"8389085755518668936","is_unconstrained":true,"custom_attributes":["abi_utility"],"abi":{"parameters":[{"name":"owner","type":{"kind":"struct","path":"aztec::protocol_types::address::aztec_address::AztecAddress","fields":[{"name":"inner","type":{"kind":"field"}}]},"visibility":"private"}],"return_type":{"abi_type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"public"},"error_types":{"459713770342432051":{"error_kind":"string","string":"Not initialized"},"13455385521185560676":{"error_kind":"string","string":"Storage slot 0 not allowed. Storage slots must start from 1."},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"},"16431471497789672479":{"error_kind":"string","string":"Index out of bounds"}}},"bytecode":"","debug_symbols":""},{"name":"__aztec_nr_internals__increment","hash":"12806230484060893311","is_unconstrained":true,"custom_attributes":["abi_public"],"abi":{"parameters":[{"name":"owner","type":{"kind":"struct","path":"aztec::protocol_types::address::aztec_address::AztecAddress","fields":[{"name":"inner","type":{"kind":"field"}}]},"visibility":"private"}],"return_type":null,"error_types":{"459713770342432051":{"error_kind":"string","string":"Not initialized"},"13455385521185560676":{"error_kind":"string","string":"Storage slot 0 not allowed. Storage slots must start from 1."},"14990209321349310352":{"error_kind":"string","string":"attempt to add with overflow"}}},"bytecode":"","debug_symbols":""},{"name":"__aztec_nr_internals__initialize","hash":"1434729420570237773","is_unconstrained":true,"custom_attributes":["abi_public","abi_initializer"],"abi":{"parameters":[{"name":"headstart","type":{"kind":"integer","sign":"unsigned","width":64},"visibility":"private"},{"name":"owner","type":{"kind":"struct","path":"aztec::protocol_types::address::aztec_addr